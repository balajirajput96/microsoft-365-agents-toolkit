{
  "schema_version": "v2",
  "name_for_human": "Plugin${{APP_NAME_SUFFIX}}",
  "description_for_model": "Plugin",
  "functions": [
    {
      "name": "listRepairs",
      "description": "Returns a list of repairs with their details and images",
      "capabilities": {
        "response_semantics": {
          "data_path": "$.results",
          "properties": {
            "title": "$.title",
            "subtitle": "$.id"
          },
          "static_template": {
            "file": "resources/adaptiveCards/listRepairs.json"
          }
        }
      }
    }
  ],
  "runtimes": [
    {
      "type": "OpenApi",
      "auth": {
        "type": "none"
      },
      "spec": {
        "url": "./openai.yml"
      }
    }
  ]
}